# .env.example — copie para .env antes de subir o docker-compose (MLOps/).
#   cp .env.example .env

# UID do seu usuário local — usado pelo Airflow para os arquivos de log
# terem o dono correto no host (evita arquivos de log criados como root).
# Linux/macOS: rode `id -u` e cole o resultado aqui.
AIRFLOW_UID=50000

# Amostra opcional para rodar o treino em máquinas com pouca RAM/CPU
# (ex.: debug rápido). Deixe comentado/vazio para treinar no dataset
# completo, que é o esperado na entrega final.
# TRAIN_SAMPLE_ROWS=15000
